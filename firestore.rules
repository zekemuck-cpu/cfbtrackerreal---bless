rules_version = '2';

// CFB Dynasty Tracker — Firestore Security Rules
//
// Source-of-truth principles:
//   1. The `users/{uid}` doc is server-controlled for subscription fields.
//      The webhook (admin SDK, bypasses rules) writes tier / status / etc.
//      Clients can READ their own user doc but cannot WRITE the
//      subscription fields directly. They can write a small allowlisted
//      set of profile fields (none currently — leaving room).
//   2. Cloud dynasties are owned by `userId`. The owner can always READ
//      them (including after subscription lapse — needed for the
//      auto-export-to-local migration). Only PREMIUM owners can WRITE.
//   3. Public dynasties (`isPublic == true` with a `shareCode`) are
//      readable by anyone, including unauthenticated visitors. Only the
//      owner can flip the public flag, and only premium owners can
//      do so (sharing is a premium feature).
//   4. `webhookEvents` and `stripeEvents` are server-only — clients
//      can't read or write them.

service cloud.firestore {
  match /databases/{database}/documents {

    // ─── Helpers ──────────────────────────────────────────────────────
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(uid) {
      return isSignedIn() && request.auth.uid == uid;
    }

    // Read the requesting user's subscription doc to determine premium
    // status. Includes past_due so a transient card decline doesn't
    // immediately revoke write access while Stripe is still retrying.
    //
    // Mirrors the client-side check in services/subscriptionService.js:
    //   - tier must be 'premium'
    //   - status must be active / trialing / past_due
    //   - if currentPeriodEnd is set, it must be in the future
    //
    // The currentPeriodEnd check is what makes beta-granted users
    // (`_devGranted: true`) lose server-side write access when their
    // 30-day grant lapses, even though their Firestore doc still
    // says tier='premium' and status='active'. Without this check, the
    // client UI would correctly go read-only at expiry but a stale
    // tab could still POST writes. We allow the field to be missing
    // for backward compat with any user docs that pre-date the field.
    function isPremium() {
      let userPath = /databases/$(database)/documents/users/$(request.auth.uid);
      let exists = exists(userPath);
      let userData = exists ? get(userPath).data : {};
      let hasPaidStatus = userData.subscriptionStatus == 'active'
                          || userData.subscriptionStatus == 'trialing'
                          || userData.subscriptionStatus == 'past_due';
      let withinPeriod = !('currentPeriodEnd' in userData)
                         || userData.currentPeriodEnd == null
                         || userData.currentPeriodEnd > request.time;
      return isSignedIn()
        && userData.tier == 'premium'
        && hasPaidStatus
        && withinPeriod;
    }

    // ─── users/{uid} ─────────────────────────────────────────────────
    // Read: only the owner.
    // Write: rejected from clients EXCEPT a narrow case — the owner may
    //   flip `pendingDowngrade` from true to false to signal that the
    //   client has finished auto-exporting cloud dynasties to local
    //   storage. Any other field change goes through the webhook
    //   (admin SDK, bypasses these rules) or the admin API.
    // Create / delete: server-only.
    match /users/{uid} {
      allow read: if isOwner(uid);

      allow update: if isOwner(uid)
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['pendingDowngrade'])
        && request.resource.data.pendingDowngrade == false;

      allow create, delete: if false;
    }

    // ─── dynasties/{id} ──────────────────────────────────────────────
    // MULTIPLAYER MODEL: every dynasty has a members[] array (legacy
    // solo dynasties get auto-migrated to members-of-1 on load). The
    // cheap-lookup mirror `memberUids[]` is what we check in rules
    // (array-contains is O(1); scanning members[] for nested fields
    // is not supported in security rules). Until a dynasty has been
    // written post-multiplayer-launch, memberUids may not exist — fall
    // back to the legacy userId check so existing solo dynasties keep
    // reading.
    //
    // Read:
    //   - Legacy owner (resource.data.userId) can always read
    //   - Active member (uid in memberUids) can read
    //   - Anyone can read a doc that is currently public
    // Create:
    //   - Must be the owner AND premium AND storageType: 'cloud'
    //   - On create, userId must equal the requester (no impersonation)
    // Update:
    //   - Owner OR active member (write authority is enforced by
    //     application code in Phase 1; Phase 3 will tighten this rule
    //     to only allow team-owners and permission holders)
    //   - Owner must remain premium
    //   - userId cannot be changed
    // Delete:
    //   - Owner only (Phase 1)
    match /dynasties/{dynastyId} {
      // SPLIT-RULE FORM: each allow-read is independently provable for
      // its query shape. A single combined `||` expression confuses
      // Firestore's query-safety analysis — specifically, the
      // `subscribeToMemberLeagues` query (`array-contains memberUids`)
      // can't be proved safe when wrapped in an OR with the legacy
      // owner check. Splitting into discrete rules lets Firestore
      // prove safety per query path.
      //
      // Each allow-read covers one access vector:
      //   1. legacy owner read (userId match)
      //   2. multiplayer member read (uid in memberUids array)
      //   3. public-share read (isPublic flag, no auth required)
      allow read: if isSignedIn()
                  && resource.data.userId == request.auth.uid;

      // CANONICAL `in resource.data.X` form for array-contains queries.
      // Use `.get(field, [])` so missing field returns empty list (no
      // type-check needed). The Firestore safe-query analyzer matches
      // this pattern against `where('memberUids', 'array-contains', X)`
      // — the `is list` form failed the analyzer's matching step.
      allow read: if isSignedIn()
                  && request.auth.uid in resource.data.get('memberUids', []);

      allow read: if resource.data.isPublic == true;

      allow create: if isPremium()
                    && request.resource.data.userId == request.auth.uid
                    && request.resource.data.storageType == 'cloud';

      // Phase 1: keep writes owner-only. Members can read but can't
      // write yet — Phase 3 will gate writes by team ownership +
      // permissions matrix.
      allow update: if isOwner(resource.data.userId)
                    && isPremium()
                    && request.resource.data.userId == resource.data.userId;

      allow delete: if isOwner(resource.data.userId);

      // Subcollections: members can read; writes still owner-only in
      // Phase 1. Same split-rule treatment as the parent so each access
      // vector is independently provable.
      function parentDynasty() {
        return get(/databases/$(database)/documents/dynasties/$(dynastyId)).data;
      }

      match /players/{playerId} {
        allow read: if isSignedIn()
                    && parentDynasty().userId == request.auth.uid;
        allow read: if isSignedIn()
                    && request.auth.uid in parentDynasty().get('memberUids', []);
        allow read: if parentDynasty().isPublic == true;

        allow write: if isPremium()
                     && parentDynasty().userId == request.auth.uid;
      }

      match /games/{gameId} {
        allow read: if isSignedIn()
                    && parentDynasty().userId == request.auth.uid;
        allow read: if isSignedIn()
                    && request.auth.uid in parentDynasty().get('memberUids', []);
        allow read: if parentDynasty().isPublic == true;

        allow write: if isPremium()
                     && parentDynasty().userId == request.auth.uid;
      }
    }

    // ─── invitations/{id} ────────────────────────────────────────────
    // League invitation docs. The commish creates them; the invitee can
    // read their own pending invites and update status to accepted/declined.
    //
    //   {
    //     dynastyId: string,
    //     dynastyName: string,
    //     dynastyOwnerUid: string,        — for commish-only update gate
    //     commissionerEmail: string,
    //     inviteeEmail: string (lowercase) — primary join key
    //     inviteeUid: string|null         — populated on accept
    //     status: 'pending'|'accepted'|'declined'|'revoked'
    //     initialTeams: number[],
    //     createdAt: Timestamp,
    //     respondedAt: Timestamp|null,
    //   }
    //
    // Read:
    //   - The invitee (matched by email — works even before they have
    //     a uid mapping, e.g. when invited by email pre-signup)
    //   - The dynasty's commish (so they can see status of sent invites)
    // Create: only the dynasty's commish (must equal request.auth.uid)
    // Update: invitee can change status to accepted/declined; commish
    //         can change status to revoked.
    // Delete: server-only (audit trail).
    match /invitations/{inviteId} {
      allow read: if isSignedIn() && (
        request.auth.token.email != null
        && resource.data.inviteeEmail == request.auth.token.email.lower()
        || resource.data.dynastyOwnerUid == request.auth.uid
      );

      allow create: if isSignedIn()
        && request.resource.data.dynastyOwnerUid == request.auth.uid
        && request.resource.data.status == 'pending';

      allow update: if isSignedIn() && (
        // Invitee responding
        (request.auth.token.email != null
         && resource.data.inviteeEmail == request.auth.token.email.lower()
         && request.resource.data.status in ['accepted', 'declined'])
        // Commish revoking
        || (resource.data.dynastyOwnerUid == request.auth.uid
            && request.resource.data.status == 'revoked')
      );

      allow delete: if false;
    }

    // ─── Server-only collections ─────────────────────────────────────
    match /webhookEvents/{eventId} {
      allow read, write: if false;
    }

    match /stripeEvents/{eventId} {
      allow read, write: if false;
    }

    // ─── Default deny ────────────────────────────────────────────────
    // Any collection not explicitly allowed above is server-only.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
