rules_version = '2';

// CFB Dynasty Tracker — Firestore Security Rules
//
// Source-of-truth principles:
//   1. The `users/{uid}` doc is server-controlled for subscription fields.
//      The webhook (admin SDK, bypasses rules) writes tier / status / etc.
//      Clients can READ their own user doc but cannot WRITE the
//      subscription fields directly. They can write a small allowlisted
//      set of profile fields (none currently — leaving room).
//   2. Cloud dynasties are owned by `userId`. The owner can always READ
//      them (including after subscription lapse — needed for the
//      auto-export-to-local migration). Premium owners can WRITE.
//   3. Shared dynasties: any uid in `editors[]` has full read+write.
//      Editors must themselves be premium to write — the dynasty itself
//      is paid for by the owner. Roles / per-team ownership / commish
//      gates are deliberately out of scope here; everyone in editors[]
//      is fully trusted.
//   4. Public dynasties (`isPublic == true` with a `shareCode`) are
//      readable by anyone, including unauthenticated visitors. Only the
//      owner can flip the public flag, and only premium owners can
//      do so (sharing is a premium feature).
//   5. `webhookEvents` and `stripeEvents` are server-only — clients
//      can't read or write them.

service cloud.firestore {
  match /databases/{database}/documents {

    // ─── Helpers ──────────────────────────────────────────────────────
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(uid) {
      return isSignedIn() && request.auth.uid == uid;
    }

    // Read the requesting user's subscription doc to determine premium
    // status. Includes past_due so a transient card decline doesn't
    // immediately revoke write access while Stripe is still retrying.
    //
    // Mirrors the client-side check in services/subscriptionService.js:
    //   - tier must be 'premium'
    //   - status must be active / trialing / past_due
    //   - if currentPeriodEnd is set, it must be in the future
    function isPremium() {
      let userPath = /databases/$(database)/documents/users/$(request.auth.uid);
      let exists = exists(userPath);
      let userData = exists ? get(userPath).data : {};
      let hasPaidStatus = userData.subscriptionStatus == 'active'
                          || userData.subscriptionStatus == 'trialing'
                          || userData.subscriptionStatus == 'past_due';
      let withinPeriod = !('currentPeriodEnd' in userData)
                         || userData.currentPeriodEnd == null
                         || userData.currentPeriodEnd > request.time;
      return isSignedIn()
        && userData.tier == 'premium'
        && hasPaidStatus
        && withinPeriod;
    }

    // ─── users/{uid} ─────────────────────────────────────────────────
    // Read: only the owner.
    // Write: rejected from clients EXCEPT a narrow case — the owner may
    //   flip `pendingDowngrade` from true to false to signal that the
    //   client has finished auto-exporting cloud dynasties to local
    //   storage. Any other field change goes through the webhook
    //   (admin SDK, bypasses these rules) or the admin API.
    // Create / delete: server-only.
    match /users/{uid} {
      allow read: if isOwner(uid);

      allow update: if isOwner(uid)
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['pendingDowngrade'])
        && request.resource.data.pendingDowngrade == false;

      allow create, delete: if false;
    }

    // ─── dynasties/{id} ──────────────────────────────────────────────
    // SHARING MODEL: every dynasty has an `editors[]` array of uids that
    // are allowed to read+write. Legacy solo dynasties auto-migrate on
    // load to `editors: [userId]`. Until that migration runs, the
    // owner's read still works via the legacy `userId` check.
    //
    // PREMIUM MODEL: only the OWNER needs premium (they pay for cloud
    // storage). Invited editors can write even on the free tier — their
    // commish is footing the storage bill.
    //
    // Read:
    //   - Legacy owner (resource.data.userId) — keeps pre-migration
    //     dynasties readable
    //   - Anyone in editors[] (post-migration; owner is included here)
    //   - Anyone (no auth required) for currently-public docs
    // Create:
    //   - Premium owner; userId must equal the requester (no impersonation)
    //   - storageType must be 'cloud'
    // Update:
    //   - Owner (must be premium — they pay for storage)
    //   - OR uid in editors[] (invited editors can write even on free tier)
    //   - OR a non-editor self-redeeming a valid invite (see below)
    //   - userId cannot be changed (ownership transfer is out of scope)
    // Delete:
    //   - Owner only
    match /dynasties/{dynastyId} {
      // Each allow-read covers one access vector (split form is needed
      // so Firestore can prove each query path's safety independently —
      // a single combined OR confuses the safe-query analyzer for
      // array-contains queries).
      allow read: if isSignedIn()
                  && resource.data.userId == request.auth.uid;

      allow read: if isSignedIn()
                  && request.auth.uid in resource.data.get('editors', []);

      allow read: if resource.data.isPublic == true;

      allow create: if isPremium()
                    && request.resource.data.userId == request.auth.uid
                    && request.resource.data.storageType == 'cloud';

      // Owner write — must be premium (paying for the cloud doc).
      allow update: if isPremium()
                    && isOwner(resource.data.userId)
                    && request.resource.data.userId == resource.data.userId;

      // Invited editor write — premium NOT required. The owner's
      // premium covers the storage bill; editors are first-class
      // collaborators regardless of their own subscription tier.
      allow update: if isSignedIn()
                    && !isOwner(resource.data.userId)
                    && request.auth.uid in resource.data.get('editors', [])
                    && request.resource.data.userId == resource.data.userId;

      // Invite redemption — a non-editor adds themselves to editors[]
      // by presenting a token. The token is verified via the invites
      // subcollection (see below): rules check that the doc at
      // dynasties/{id}/invites/{token} (a) exists, (b) is unredeemed,
      // (c) is unexpired, (d) was just marked redeemedBy this uid in
      // the same client batch.
      //
      // The client passes the token in `request.resource.data.lastRedemption.token`.
      // It's a transient marker (cleared on the next ordinary editor write)
      // that pins down WHICH invite is being claimed, since rules can't
      // iterate the invites subcollection.
      allow update: if isSignedIn()
                    && !(request.auth.uid in resource.data.get('editors', []))
                    && request.resource.data.userId == resource.data.userId
                    // Only editors and lastRedemption can change in a redemption.
                    && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['editors', 'lastRedemption'])
                    // The new editors[] is the old list with EXACTLY this user appended.
                    && request.resource.data.editors.size() == resource.data.get('editors', []).size() + 1
                    && request.auth.uid in request.resource.data.editors
                    // The marker must name THIS user.
                    && request.resource.data.lastRedemption.uid == request.auth.uid
                    // The invite doc must exist, be redeemed by this uid, and unexpired.
                    && exists(/databases/$(database)/documents/dynasties/$(dynastyId)/invites/$(request.resource.data.lastRedemption.token))
                    && get(/databases/$(database)/documents/dynasties/$(dynastyId)/invites/$(request.resource.data.lastRedemption.token)).data.redeemedBy == request.auth.uid;

      allow delete: if isOwner(resource.data.userId);

      // Subcollections inherit the same access vectors. Owner needs
      // premium (storage cost); invited editors write freely.
      function parentDynasty() {
        return get(/databases/$(database)/documents/dynasties/$(dynastyId)).data;
      }

      match /players/{playerId} {
        allow read: if isSignedIn()
                    && parentDynasty().userId == request.auth.uid;
        allow read: if isSignedIn()
                    && request.auth.uid in parentDynasty().get('editors', []);
        allow read: if parentDynasty().isPublic == true;

        // Owner write requires premium; invited editors don't.
        allow write: if isPremium()
                     && parentDynasty().userId == request.auth.uid;
        allow write: if isSignedIn()
                     && parentDynasty().userId != request.auth.uid
                     && request.auth.uid in parentDynasty().get('editors', []);
      }

      match /games/{gameId} {
        allow read: if isSignedIn()
                    && parentDynasty().userId == request.auth.uid;
        allow read: if isSignedIn()
                    && request.auth.uid in parentDynasty().get('editors', []);
        allow read: if parentDynasty().isPublic == true;

        // ── Per-team write gating ────────────────────────────────
        // Owner: any team, must be premium (storage cost).
        // Co-commish: any team, no premium required.
        // Regular member: only games involving a team they manage —
        //   either side (team1Tid OR team2Tid) must appear in their
        //   memberTeams[uid] list. Both the OLD doc (resource, for
        //   updates/deletes) AND the NEW doc (request.resource, for
        //   creates/updates) are checked so members can't swap an
        //   opponent's tid to their own to sneak in a write.
        // Tid-less games (CFP shells, bowl bids with TBD positions):
        //   only owner / co-commish — they're "league-level" before
        //   the bracket fills.

        // Owner write — premium required.
        allow write: if isPremium()
                     && parentDynasty().userId == request.auth.uid;

        // Co-commish — any team, no premium required.
        allow write: if isSignedIn()
                     && parentDynasty().userId != request.auth.uid
                     && request.auth.uid in parentDynasty().get('coCommishes', []);

        // Regular member — only their team's games.
        allow write: if isSignedIn()
                     && parentDynasty().userId != request.auth.uid
                     && request.auth.uid in parentDynasty().get('editors', [])
                     && !(request.auth.uid in parentDynasty().get('coCommishes', []))
                     && parentDynasty().get('memberTeams', {}).get(request.auth.uid, []).size() > 0
                     && (
                       (resource != null
                        && (
                          (resource.data.get('team1Tid', null) != null
                           && resource.data.team1Tid in parentDynasty().memberTeams[request.auth.uid])
                          || (resource.data.get('team2Tid', null) != null
                              && resource.data.team2Tid in parentDynasty().memberTeams[request.auth.uid])
                        ))
                       || (request.resource != null
                           && (
                             (request.resource.data.get('team1Tid', null) != null
                              && request.resource.data.team1Tid in parentDynasty().memberTeams[request.auth.uid])
                             || (request.resource.data.get('team2Tid', null) != null
                                 && request.resource.data.team2Tid in parentDynasty().memberTeams[request.auth.uid])
                           ))
                     );
      }

      // ─── Season-scoped data (subcollection) ─────────────────────
      // Per-year docs: dynasties/{id}/seasons/{year}
      // Holds every field that used to live on the main doc as a
      // ByYear or ByTeamYear map (allAmericans, awards, conference
      // standings, recruitingCommitmentsByTeam, schedulesByTeam, etc).
      //
      // Rationale: long-running dynasties were pushing the parent
      // doc past the 1 MiB Firestore cap. Sharding the season-scoped
      // data into per-year docs keeps each doc well under the cap
      // regardless of how many seasons accumulate.
      //
      // Same access model as players/games/weekRecaps: owner needs
      // premium, invited editors can write without their own
      // subscription (the parent dynasty's premium covers storage).
      match /seasons/{seasonId} {
        allow read: if isSignedIn()
                    && parentDynasty().userId == request.auth.uid;
        allow read: if isSignedIn()
                    && request.auth.uid in parentDynasty().get('editors', []);
        allow read: if parentDynasty().isPublic == true;

        allow write: if isPremium()
                     && parentDynasty().userId == request.auth.uid;
        allow write: if isSignedIn()
                     && parentDynasty().userId != request.auth.uid
                     && request.auth.uid in parentDynasty().get('editors', []);
      }

      // ─── Week recaps (subcollection) ────────────────────────────
      // Per-week AI recap docs: dynasties/{id}/weekRecaps/{year-week}
      // Doc shape: { year, week, generatedAt, text }
      //
      // Lifted out of the main dynasty doc because long-running
      // dynasties were pushing the parent past the 1 MB Firestore size
      // cap, at which point ALL writes to the dynasty failed. Same
      // read/write model as players: owner needs premium, invited
      // editors can write without their own subscription.
      match /weekRecaps/{recapId} {
        allow read: if isSignedIn()
                    && parentDynasty().userId == request.auth.uid;
        allow read: if isSignedIn()
                    && request.auth.uid in parentDynasty().get('editors', []);
        allow read: if parentDynasty().isPublic == true;

        allow write: if isPremium()
                     && parentDynasty().userId == request.auth.uid;
        allow write: if isSignedIn()
                     && parentDynasty().userId != request.auth.uid
                     && request.auth.uid in parentDynasty().get('editors', []);
      }

      // ─── Invite tokens (subcollection) ──────────────────────────
      // Token-keyed docs: dynasties/{id}/invites/{token}
      // Doc shape: { role, createdBy, createdAt, expiresAt?, label?,
      //              redeemedBy?, redeemedAt? }
      //
      // get: any signed-in user can fetch ONE invite by its exact token
      //   (URL-shared join page). Non-editors can't enumerate.
      // list: editors only — the Members page subscribes to this
      //   collection so the commish can see + revoke pending invites.
      // create/delete: editors only (commish + co-commishes generate
      //   and revoke invites).
      // update: redemption only — anyone signed in can mark an
      //   unredeemed, unexpired invite as redeemed by themselves. The
      //   actual editors[] write happens on the parent dynasty doc
      //   (see the redemption rule above).
      match /invites/{token} {
        allow get: if isSignedIn();

        allow list: if isSignedIn()
                    && request.auth.uid in parentDynasty().get('editors', []);

        allow create, delete: if isSignedIn()
                              && request.auth.uid in parentDynasty().get('editors', []);

        allow update: if isSignedIn()
                      && resource.data.redeemedBy == null
                      && (
                        !('expiresAt' in resource.data)
                        || resource.data.expiresAt == null
                        || resource.data.expiresAt > request.time
                      )
                      && request.resource.data.redeemedBy == request.auth.uid
                      && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['redeemedBy', 'redeemedAt']);
      }
    }

    // ─── Server-only collections ─────────────────────────────────────
    match /webhookEvents/{eventId} {
      allow read, write: if false;
    }

    match /stripeEvents/{eventId} {
      allow read, write: if false;
    }

    // ─── Default deny ────────────────────────────────────────────────
    // Any collection not explicitly allowed above is server-only.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
