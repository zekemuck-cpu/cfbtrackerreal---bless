rules_version = '2';

// Firebase Storage rules for CFB Dynasty Tracker.
//
// All app uploads land under /images/. Card art and player photos are
// publicly viewable (the URL with token is what gets baked into shared
// dynasties), so reads are open. Writes require an authenticated user
// and are capped at 32 MB to mirror the old imgbb limit + filtered to
// image MIME types so the bucket can't be repurposed for arbitrary
// uploads.
service firebase.storage {
  match /b/{bucket}/o {
    match /images/{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null
                    && request.resource.size < 32 * 1024 * 1024
                    && request.resource.contentType.matches('image/.*');
    }
  }
}
